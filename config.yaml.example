# Copy to config.yaml and customize (config.yaml is gitignored).
#
# Required environment variables:
#   ADZUNA_APP_ID, ADZUNA_APP_KEY  — from https://developer.adzuna.com/
#   GROQ_API_KEY                    — from https://console.groq.com/ (if llm.enabled)
#   SMTP_USER, SMTP_PASSWORD        — Gmail address and app password (or your SMTP credentials)
#
# PowerShell example:
#   $env:ADZUNA_APP_ID = "your-id"
#   $env:ADZUNA_APP_KEY = "your-key"
#   $env:GROQ_API_KEY = "gsk_..."
#   $env:SMTP_USER = "you@gmail.com"
#   $env:SMTP_PASSWORD = "your-app-password"

primary:
  source: adzuna

defaults:
  primary:
    search:
      location: ""
    filters:
      min_salary: 0
      max_salary: 0
      job_type: ""
      remote_only: false
      required_keywords: []
      exclude_keywords:
        - "SC Clearance"
      categories: []
  llm:
    must_have_keywords: []
    nice_to_have_keywords: []
    avoid_keywords:
      - "SC Clearance"

roles:
  - name: "Example Role"
    enabled: true
    priority: 1
    primary:
      source: adzuna
      search:
        keywords:
          - "Solutions Architect"
        location: "London"
      filters:
        min_salary: 0
        max_salary: 0
        job_type: ""
        required_keywords: []
        exclude_keywords:
          - "principal"
          - "director"
        categories: []
    llm:
      target_roles:
        - "Solution Architect"
      must_have_keywords: []
      nice_to_have_keywords:
        - "AWS"
        - "Architecture"
      avoid_keywords:
        - "SC Clearance"
      max_jobs_to_evaluate: 120
      top_k: 30

adzuna:
  app_id_env: "ADZUNA_APP_ID"
  app_key_env: "ADZUNA_APP_KEY"
  country: "gb"
  results_per_page: 50
  max_pages: 5

llm:
  enabled: true
  mode: "replace"
  endpoint: "https://api.groq.com/openai/v1/chat/completions"
  model: "llama-3.3-70b-versatile"
  api_key_env: "GROQ_API_KEY"
  use_json_mode: true
  max_jobs_to_evaluate: 120
  top_k: 30
  max_description_chars: 400
  timeout_seconds: 45

email:
  smtp_host: "smtp.gmail.com"
  smtp_port: 587
  smtp_user_env: "SMTP_USER"
  smtp_password_env: "SMTP_PASSWORD"
  to_address: "you@gmail.com"
  send_if_empty: false
